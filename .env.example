SECRET_KEY=tu-secret-key-aqui
DEBUG=True

# Email — Gmail SMTP con App Password
# 1. Activá verificación en 2 pasos en tu cuenta Google
# 2. Ir a: myaccount.google.com → Seguridad → Contraseñas de aplicaciones
# 3. Crear una para "Correo / Windows" y pegar la clave de 16 dígitos abajo
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=somosnutricionclick@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=NutricionClick <somosnutricionclick@gmail.com>
ADMIN_EMAIL=somosnutricionclick@gmail.com

# Turnero online / Mercado Pago
# 1. Crear una aplicación en https://www.mercadopago.com.ar/developers/panel/app
#    (Pagos online → CheckoutPro, marcar "plataforma o marketplace")
# 2. Configurar la Redirect URI: https://TU-DOMINIO/turnero/mp/callback/
# 3. Copiar App ID y Client Secret acá:
SITE_URL=http://localhost:8000
MP_APP_ID=
MP_CLIENT_SECRET=
# Comisión de la plataforma por seña cobrada, en ARS (0 = sin comisión)
MP_MARKETPLACE_FEE=0
