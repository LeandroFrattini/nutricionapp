SECRET_KEY=tu-secret-key-aqui
# generarla con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# Base de datos — dejala VACÍA en tu compu (sigue usando SQLite como siempre).
# En Render, cuando conectás una base de Postgres al servicio, esta variable
# se completa sola — no hay que pegarla a mano.
DATABASE_URL=

# Almacenamiento de fotos/archivos (Supabase Storage, compatible con S3) —
# dejalo vacío en tu compu (sigue guardando en la carpeta media/ local).
# En producción, completalo con los datos del bucket que crees en Supabase.
SUPABASE_STORAGE_BUCKET=
SUPABASE_S3_ENDPOINT_URL=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_REGION=us-east-1

# DEBUG=True SOLO en tu máquina para desarrollar. En el servidor real
# (con datos de pacientes de verdad) tiene que estar en False o directamente
# no puesto acá — así, si te olvidás de configurarlo, el sitio arranca
# seguro por default en vez de exponer errores con detalle a cualquiera.
DEBUG=True

# En producción, poné acá tu dominio real (separados por coma si hay más de uno)
ALLOWED_HOSTS=localhost,127.0.0.1
# Si servís desde HTTPS con dominio propio, agregalo acá también (con https://)
# para que los formularios (login, contacto, etc.) no se rechacen por CSRF.
CSRF_TRUSTED_ORIGINS=

# URL del panel de administración — cambiala por algo propio y no adivinable
# (no dejes "admin/"). Podés generar una así:
# python -c "import secrets; print('panel-' + secrets.token_hex(4))"
ADMIN_URL=panel-cambiame123/

# Email — Gmail SMTP con App Password
# 1. Activá verificación en 2 pasos en tu cuenta Google
# 2. Ir a: myaccount.google.com → Seguridad → Contraseñas de aplicaciones
# 3. Crear una para "Correo / Windows" y pegar la clave de 16 dígitos abajo
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=somosnutricionclick@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=NutricionClick <somosnutricionclick@gmail.com>
ADMIN_EMAIL=somosnutricionclick@gmail.com
# WhatsApp del negocio (solo dígitos con código de país, sin +), para el botón del mail de planes
ADMIN_WHATSAPP=

# Turnero online / Mercado Pago
# 1. Crear una aplicación en https://www.mercadopago.com.ar/developers/panel/app
#    (Pagos online → CheckoutPro, marcar "plataforma o marketplace")
# 2. Configurar la Redirect URI: https://TU-DOMINIO/turnero/mp/callback/
# 3. Copiar App ID y Client Secret acá:
SITE_URL=http://localhost:8000
MP_APP_ID=
MP_CLIENT_SECRET=
# Comisión de la plataforma por seña cobrada, en ARS (0 = sin comisión)
MP_MARKETPLACE_FEE=0

# Links de suscripción de Mercado Pago para TUS planes (Básico $15.000 / Completo $40.000)
# Se crean en https://www.mercadopago.com.ar/subscriptions/plans (esto es aparte del turnero
# de arriba: acá es MP cobrándole a los nutricionistas la suscripción a la plataforma).
# Si los dejás vacíos, el mail de planes manda a /registro/ en su lugar.
MP_LINK_BASICO=
MP_LINK_PREMIUM=

# Access Token de TU cuenta de Mercado Pago (distinto de MP_APP_ID/MP_CLIENT_SECRET
# de arriba) — se usa para cobrar automático la suscripción a la plataforma
# (alta y renovaciones, cada una como pago único por la cantidad de meses que
# elija el profesional). Se saca de la misma página de developers, sección
# "Credenciales de producción" (o "de prueba" mientras testeás).
MP_ACCESS_TOKEN_PLATAFORMA=

# Clave secreta del webhook de pagos de suscripción (verifica que la
# notificación vino realmente de Mercado Pago).
MP_WEBHOOK_SECRET=
